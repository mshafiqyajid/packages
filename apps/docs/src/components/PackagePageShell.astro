---
import { lastUpdatedFor, formatLastUpdated, versionFor } from "~/lib/lastUpdated";

export interface Props {
  name: string;
  /** Hardcoded version override. Falls back to the package's package.json. */
  version?: string;
  description: string;
  size: string;
  framework?: string;
}
const { name, version: versionProp, description, size, framework = "react" } = Astro.props;
const version = versionProp ?? versionFor(name) ?? "—";
const npmUrl = `https://www.npmjs.com/package/@mshafiqyajid/${name}`;
const githubUrl = `https://github.com/mshafiqyajid/packages/tree/main/packages/${name}`;

const lastUpdatedIso = lastUpdatedFor(`packages/${name}`);
const lastUpdated = formatLastUpdated(lastUpdatedIso);
---

<div class="pkg-header">
  <div class="pkg-header__eyebrow">
    <span class="pkg-header__badge pkg-header__badge--framework">{framework}</span>
    <span class="pkg-header__badge">{size}</span>
    <span class="pkg-header__badge">0 deps</span>
    <a href={npmUrl} target="_blank" rel="noreferrer" class="pkg-header__badge pkg-header__badge--link">
      v{version} ↗
    </a>
    <a href={githubUrl} target="_blank" rel="noreferrer" class="pkg-header__badge pkg-header__badge--link">
      GitHub ↗
    </a>
    {lastUpdated && lastUpdatedIso && (
      <time
        class="pkg-header__badge pkg-header__badge--updated"
        datetime={lastUpdatedIso}
        title={`Last updated ${lastUpdatedIso}`}
      >
        Updated {lastUpdated}
      </time>
    )}
  </div>
  <h1 class="pkg-header__name">
    <span class="pkg-header__scope">@mshafiqyajid/</span>{name}
  </h1>
  <p class="pkg-header__desc">{description}</p>
</div>

<slot />

<style>
  .pkg-header {
    padding-bottom: 2rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .pkg-header__eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }
  .pkg-header__badge {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: "JetBrains Mono", monospace;
    padding: 2px 7px;
    border-radius: 4px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--fg-subtle);
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .pkg-header__badge--framework {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
    color: var(--accent);
  }
  .pkg-header__badge--link {
    color: var(--fg-muted);
    transition: color 120ms ease, border-color 120ms ease;
  }
  .pkg-header__badge--link:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
  .pkg-header__badge--updated {
    color: var(--fg-subtle);
    font-style: normal;
  }
  .pkg-header__name {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-family: "JetBrains Mono", monospace;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
    line-height: 1.15;
  }
  .pkg-header__scope { color: var(--fg-subtle); }
  .pkg-header__desc {
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    max-width: 580px;
  }

  /* ---- Section headings ---- */
  :global(.pkg-section) { margin-top: 2.5rem; }
  :global(.pkg-section > p) {
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  :global(.pkg-section h2) {
    font-size: 1.15rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  :global(.pkg-section h3) {
    font-size: 0.95rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--fg);
  }
</style>
