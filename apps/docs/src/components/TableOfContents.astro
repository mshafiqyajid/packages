---
// Renders a TOC populated client-side by reading the page's <h2> headings.
// Right sidebar on desktop, hidden on mobile (the user can scroll instead).
---

<aside class="toc" aria-label="On this page">
  <div class="toc__title">On this page</div>
  <nav class="toc__nav" id="toc-nav"></nav>
</aside>

<script>
  const nav = document.getElementById("toc-nav");
  if (nav) {
    const main = document.querySelector("main");
    const headings = Array.from(main?.querySelectorAll("h2[id]") ?? []) as HTMLElement[];

    if (headings.length === 0) {
      // Hide TOC entirely if there's nothing to show
      const aside = document.querySelector(".toc") as HTMLElement | null;
      if (aside) aside.style.display = "none";
    } else {
      const links: HTMLAnchorElement[] = headings.map((h) => {
        const a = document.createElement("a");
        a.href = `#${h.id}`;
        a.textContent = h.textContent?.replace(/#$/, "").trim() ?? "";
        a.className = "toc__link";
        nav.appendChild(a);
        return a;
      });

      // Highlight the heading currently in view
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((e) => e.isIntersecting);
          if (visible.length === 0) return;
          // Pick the topmost visible
          const topmost = visible.reduce((prev, curr) =>
            curr.boundingClientRect.top < prev.boundingClientRect.top ? curr : prev,
          );
          const id = topmost.target.id;
          links.forEach((a) => {
            if (a.getAttribute("href") === `#${id}`) {
              a.dataset.active = "true";
            } else {
              delete a.dataset.active;
            }
          });
        },
        { rootMargin: "-80px 0px -65% 0px", threshold: 0 },
      );

      headings.forEach((h) => observer.observe(h));
    }
  }
</script>

<style>
  .toc {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    align-self: flex-start;
    max-height: calc(100vh - var(--header-height) - 4rem);
    overflow-y: auto;
    padding: 0 1rem;
  }
  .toc__title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-subtle);
    margin-bottom: 0.5rem;
  }
  .toc__nav {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border-left: 1px solid var(--border);
  }
  .toc__nav :global(.toc__link) {
    font-size: 0.82rem;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0.25rem 0.65rem;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 140ms ease, border-color 140ms ease;
    line-height: 1.4;
  }
  .toc__nav :global(.toc__link:hover) {
    color: var(--fg);
    text-decoration: none;
  }
  .toc__nav :global(.toc__link[data-active="true"]) {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  @media (max-width: 1100px) {
    .toc { display: none; }
  }
</style>
