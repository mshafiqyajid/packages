---
// Renders at <body> root (NOT inside the Header) — the Header has
// `backdrop-filter`, which creates a containing block for fixed-positioned
// descendants. Putting the drawer inside it would trap it behind the 58px
// header strip and the user could no longer see the menu.
---
<div id="mobile-drawer" class="mobile-drawer" aria-hidden="true">
  <div class="mobile-drawer__backdrop" data-close></div>
  <div class="mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="Navigation">
    <button class="mobile-drawer__close" aria-label="Close navigation" data-close>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div id="mobile-drawer-content" class="mobile-drawer__content"></div>
  </div>
</div>

<script>
  const trigger = document.getElementById("mobile-nav-trigger") as HTMLButtonElement | null;
  const drawer = document.getElementById("mobile-drawer") as HTMLElement | null;
  const content = document.getElementById("mobile-drawer-content") as HTMLElement | null;
  if (trigger && drawer && content) {
    const sidebar = document.querySelector(".sidebar") as HTMLElement | null;
    if (sidebar) {
      // Clone sidebar contents into the drawer.
      content.innerHTML = sidebar.innerHTML;
    }

    const open = () => {
      drawer.dataset.open = "true";
      drawer.setAttribute("aria-hidden", "false");
      trigger.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      delete drawer.dataset.open;
      drawer.setAttribute("aria-hidden", "true");
      trigger.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    trigger.addEventListener("click", open);
    drawer.querySelectorAll<HTMLElement>("[data-close]").forEach((el) => {
      el.addEventListener("click", close);
    });
    drawer.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("a")) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && drawer.dataset.open) close();
    });

    // Auto-close when crossing back to desktop width.
    const mql = window.matchMedia("(min-width: 769px)");
    mql.addEventListener("change", (e) => {
      if (e.matches && drawer.dataset.open) close();
    });
  }
</script>

<style is:global>
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-drawer[data-open="true"] {
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 200ms ease;
    cursor: pointer;
  }
  .mobile-drawer[data-open="true"] .mobile-drawer__backdrop { opacity: 1; }

  .mobile-drawer__panel {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: min(300px, 86vw);
    background: var(--bg);
    border-right: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    transform: translateX(-100%);
    transition: transform 240ms cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-top: calc(3rem + env(safe-area-inset-top, 0px));
    padding-left: max(0px, env(safe-area-inset-left, 0px));
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .mobile-drawer[data-open="true"] .mobile-drawer__panel {
    transform: translateX(0);
  }

  .mobile-drawer__close {
    position: absolute;
    top: calc(0.6rem + env(safe-area-inset-top, 0px));
    right: 0.6rem;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--fg-muted);
    cursor: pointer;
    border-radius: var(--radius);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 140ms ease, background 140ms ease;
    z-index: 1;
  }
  .mobile-drawer__close:hover {
    background: var(--bg-subtle);
    color: var(--fg);
  }

  /* Inner sidebar overrides — the drawer reuses the original sidebar markup. */
  .mobile-drawer__content .sidebar {
    display: block !important;
    position: static !important;
    height: auto !important;
    border-right: none !important;
    padding: 0 !important;
    width: 100% !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-drawer__panel,
    .mobile-drawer__backdrop { transition: none; }
  }
</style>
