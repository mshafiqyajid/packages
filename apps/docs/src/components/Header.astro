---
---
<header class="header">
  <div class="header__inner">
    <div class="header__left">
      <slot name="mobile-nav" />
      <a href="/" class="header__logo">
        <span class="header__logo-mark">@mshafiqyajid</span>
        <span class="header__logo-slash">/</span>
        <span class="header__logo-name">packages</span>
      </a>
    </div>

    <nav class="header__nav">
      <a href="https://github.com/mshafiqyajid/packages" target="_blank" rel="noreferrer" class="header__link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-label="GitHub">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="header__link-label">GitHub</span>
      </a>
      <button id="theme-toggle" class="header__theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("theme-toggle")!;
  toggle.addEventListener("click", () => {
    const current = document.documentElement.dataset.theme ?? "light";
    const next = current === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("theme", next);
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }
  .header__inner {
    max-width: 1400px;
    margin: 0 auto;
    height: 100%;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .header__left { display: flex; align-items: center; }
  .header__logo {
    display: flex;
    align-items: center;
    gap: 2px;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--fg);
    text-decoration: none;
  }
  .header__logo:hover { text-decoration: none; color: var(--fg); }
  .header__logo-mark { color: var(--accent); }
  .header__logo-slash { color: var(--fg-subtle); margin: 0 1px; }
  .header__logo-name { color: var(--fg-muted); }
  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius);
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 160ms ease, background 160ms ease;
  }
  .header__link:hover {
    color: var(--fg);
    background: var(--bg-subtle);
    text-decoration: none;
  }
  .header__link-label { display: none; }
  @media (min-width: 480px) { .header__link-label { display: inline; } }
  .header__theme-toggle {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 160ms ease, background 160ms ease;
  }
  .header__theme-toggle:hover { color: var(--fg); background: var(--bg-subtle); }
  :root[data-theme="dark"] .icon-sun { display: block; }
  :root[data-theme="dark"] .icon-moon { display: none; }
  :root:not([data-theme="dark"]) .icon-sun { display: none; }
  :root:not([data-theme="dark"]) .icon-moon { display: block; }
</style>
