---
import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import path from "node:path";
import { categories, NEW_SLUGS } from "~/data/nav";
import { validateNav } from "~/lib/validateNav";
import SidebarLink from "./SidebarLink";

validateNav();

interface Props {
  active?: string;
}
const { active } = Astro.props;

const ROOT = fileURLToPath(new URL("../../../../", import.meta.url));
function pkgVersion(slug: string): string {
  try {
    const pkgPath = path.join(ROOT, "packages", `react-${slug}`, "package.json");
    const json = JSON.parse(readFileSync(pkgPath, "utf-8")) as { version?: string };
    return json.version ?? "?";
  } catch {
    return "?";
  }
}

const categoriesWithVersions = categories.map((cat) => ({
  ...cat,
  items: cat.items.map((m) => ({ ...m, version: pkgVersion(m.slug), isNew: NEW_SLUGS.has(m.slug) })),
}));
---

<nav class="sidebar" id="sidebar" aria-label="Package navigation">
  <div class="sidebar__inner">
    <a href="/" class="sidebar__home">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Home
    </a>

    {categoriesWithVersions.map((cat) => (
      <div class="sidebar__group">
        <div class="sidebar__group-label">{cat.label}</div>
        <ul class="sidebar__list">
          {cat.items.map((item) => (
            <li>
              <SidebarLink
                client:visible
                slug={item.slug}
                label={item.label}
                icon={item.icon}
                description={item.description}
                version={item.version}
                isNew={item.isNew}
                isActive={active === item.slug}
              />
            </li>
          ))}
        </ul>
      </div>
    ))}

  </div>
</nav>

<style is:global>
  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
    border-right: 1px solid var(--border);
    padding: 0.5rem 0 1rem;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: scrollbar-color 200ms ease;
  }
  .sidebar:hover { scrollbar-color: var(--border) transparent; }
  .sidebar::-webkit-scrollbar { width: 6px; }
  .sidebar::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 3px;
    transition: background 200ms ease;
  }
  .sidebar:hover::-webkit-scrollbar-thumb { background: var(--border); }
  .sidebar__inner {
    display: flex;
    flex-direction: column;
    padding: 0 0.625rem;
  }
  .sidebar__home {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.55rem;
    border-radius: 6px;
    color: var(--fg-muted);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 140ms ease, background 140ms ease;
    margin-bottom: 0.4rem;
  }
  .sidebar__home:hover { color: var(--fg); background: var(--bg-subtle); text-decoration: none; }
  .sidebar__group { margin-top: 0.5rem; }
  .sidebar__group-label {
    padding: 0 0.55rem 0.2rem;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .sidebar__group-label--muted { opacity: 0.5; }
  .sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.18rem 0.5rem;
    border-radius: 4px;
    font-size: 0.77rem;
    font-weight: 450;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 120ms ease, background 120ms ease;
    cursor: pointer;
  }
  a.sidebar__link:hover { color: var(--fg); background: var(--bg-subtle); text-decoration: none; }
  .sidebar__link--active {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    font-weight: 500;
  }
  .sidebar__link--active:hover {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
  }
  .sidebar__link--disabled { opacity: 0.35; cursor: default; }
  .sidebar__icon { font-size: 0.82em; flex-shrink: 0; opacity: 0.8; }
  .sidebar__name { flex: 1; min-width: 0; }
  .sidebar__version {
    font-size: 0.64rem;
    font-family: "JetBrains Mono", monospace;
    color: var(--fg-subtle);
    opacity: 0;
    transition: opacity 120ms ease;
    flex-shrink: 0;
  }
  .sidebar__link:hover .sidebar__version,
  .sidebar__link--active .sidebar__version { opacity: 1; }
  .sidebar__link--active .sidebar__version { color: var(--accent); opacity: 0.7; }
  .sidebar__new {
    font-size: 0.6rem;
    font-weight: 600;
    line-height: 1;
    padding: 2px 5px;
    border-radius: 99px;
    background: color-mix(in srgb, #16a34a 12%, transparent);
    color: #16a34a;
    flex-shrink: 0;
    align-self: center;
  }
  [data-theme="dark"] .sidebar__new {
    background: color-mix(in srgb, #4ade80 12%, transparent);
    color: #4ade80;
  }
  @media (max-width: 768px) { .sidebar { display: none; } }

  /* Hover-card content shown for each sidebar package link. */
  .sidebar-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: 260px;
  }
  .sidebar-card__name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.2;
  }
  .sidebar-card__desc {
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--fg-muted);
  }
</style>

<script is:inline>
  (function () {
    const KEY = "sidebar-scroll";
    const el = document.getElementById("sidebar");
    if (!el) return;

    // Restore saved position, or scroll active link into view
    const saved = sessionStorage.getItem(KEY);
    if (saved) {
      el.scrollTop = parseInt(saved, 10);
    } else {
      const active = el.querySelector(".sidebar__link--active");
      if (active) active.scrollIntoView({ block: "nearest" });
    }

    // Save on scroll (debounced)
    let t;
    el.addEventListener("scroll", function () {
      clearTimeout(t);
      t = setTimeout(function () {
        sessionStorage.setItem(KEY, el.scrollTop);
      }, 100);
    }, { passive: true });
  })();
</script>
