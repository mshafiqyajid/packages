---
// Trigger button only. The drawer it controls is rendered at <body> root
// (see <MobileNavDrawer />) so it isn't trapped inside the Header's
// backdrop-filter containing block.
---
<button
  id="mobile-nav-trigger"
  class="mobile-nav-trigger"
  aria-label="Open navigation"
  aria-controls="mobile-drawer"
  aria-expanded="false"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<style is:global>
  .mobile-nav-trigger {
    display: none;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--fg-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: color 140ms ease, background 140ms ease, border-color 140ms ease;
  }
  .mobile-nav-trigger:hover {
    color: var(--fg);
    background: var(--bg-subtle);
    border-color: var(--border-strong);
  }
  .mobile-nav-trigger:active { transform: scale(0.95); }
  @media (max-width: 768px) {
    .mobile-nav-trigger { display: inline-flex; }
  }
</style>
