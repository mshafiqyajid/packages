---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import {
  CopyButtonPreview,
  OTPInputPreview,
  SegmentedControlPreview,
  RatingPreview,
  ColorPreview,
  TooltipPreview,
  AccordionPreview,
  TabsPreview,
  ToastPreview,
  SelectPreview,
  ModalPreview,
  SwitchPreview,
  BadgePreview,
  AvatarPreview,
  ProgressPreview,
  SliderPreview,
  PopoverPreview,
  DropdownMenuPreview,
  TimelinePreview,
} from "~/components/LandingPreviews";

const packages = [
  {
    slug: "copy-button",
    name: "react-copy-button",
    desc: "Copy-to-clipboard with headless hook, styled variant, animations, async source, and tooltip.",
    version: "0.1.1",
    size: "~7 KB",
    tags: ["hook", "headless", "animated"],
  },
  {
    slug: "otp-input",
    name: "react-otp-input",
    desc: "OTP / verification-code input with smart paste, full keyboard nav, masking, and group separators.",
    version: "0.1.0",
    size: "~20 KB",
    tags: ["hook", "a11y", "paste"],
  },
  {
    slug: "segmented-control",
    name: "react-segmented-control",
    desc: "iOS-style segmented picker with buttery sliding indicator, ResizeObserver measurement, and generic type support.",
    version: "0.1.0",
    size: "~17 KB",
    tags: ["hook", "animated", "generic"],
  },
  {
    slug: "rating",
    name: "react-rating",
    desc: "Star-rating with half-step support, hover preview, custom icons, CSS clip-path fills, and keyboard nav.",
    version: "0.1.0",
    size: "~18 KB",
    tags: ["hook", "half-step", "custom icons"],
  },
  {
    slug: "color",
    name: "react-color",
    desc: "Drop-in replacement for react-color. Zero dependencies, ~11 KB. Hex/RGB/HSL/HSV pickers and pure color math.",
    version: "0.1.1",
    size: "~11 KB",
    tags: ["color math", "zero deps", "drop-in"],
    highlight: "Drop-in for react-color",
  },
  {
    slug: "tooltip",
    name: "react-tooltip",
    desc: "Accessible tooltip with smart flip positioning, animated entry, keyboard dismiss, and zero dependencies.",
    version: "0.1.0",
    size: "~6 KB",
    tags: ["accessible", "animated", "flip"],
  },
  {
    slug: "accordion",
    name: "react-accordion",
    desc: "Accessible accordion with single/multiple mode, smooth CSS grid height animation, and full keyboard navigation.",
    version: "0.1.0",
    size: "~8 KB",
    tags: ["animated", "a11y", "keyboard"],
  },
  {
    slug: "tabs",
    name: "react-tabs",
    desc: "Accessible tabs with line, solid, and pill variants. Sliding indicator driven by ResizeObserver. Controlled and uncontrolled.",
    version: "0.1.0",
    size: "~9 KB",
    tags: ["animated", "controlled", "a11y"],
  },
  {
    slug: "toast",
    name: "react-toast",
    desc: "Toast notifications with singleton store — no context needed. Six positions, five types, progress bar, auto-dismiss.",
    version: "0.1.0",
    size: "~10 KB",
    tags: ["singleton", "animated", "queue"],
  },
  {
    slug: "select",
    name: "react-select",
    desc: "Custom select dropdown with single and multi-select, searchable, clearable, chips, and portal positioning.",
    version: "0.1.0",
    size: "~12 KB",
    tags: ["multi", "searchable", "portal"],
  },
  {
    slug: "modal",
    name: "react-modal",
    desc: "Modal dialog and drawer with focus trap, scroll lock, Escape to close, and smooth enter/exit animations.",
    version: "0.1.0",
    size: "~11 KB",
    tags: ["focus trap", "drawer", "animated"],
  },
  {
    slug: "switch",
    name: "react-switch",
    desc: "Toggle switch with sizes, tones, label positioning, and loading spinner inside the thumb.",
    version: "0.1.0",
    size: "~5 KB",
    tags: ["toggle", "accessible", "animated"],
  },
  {
    slug: "badge",
    name: "react-badge",
    desc: "Badge, chip, and tag component. Three variants, six tones, dot indicator, count, and dismissible.",
    version: "0.1.0",
    size: "~4 KB",
    tags: ["chip", "tag", "dismissible"],
  },
  {
    slug: "avatar",
    name: "react-avatar",
    desc: "Avatar with image, initials fallback, presence status dot, border ring, and group stacking.",
    version: "0.1.0",
    size: "~6 KB",
    tags: ["initials", "group", "status"],
  },
  {
    slug: "progress",
    name: "react-progress",
    desc: "Progress bar and circular ring. Indeterminate state, animated stripe, five tones, value display.",
    version: "0.1.0",
    size: "~6 KB",
    tags: ["bar", "circle", "indeterminate"],
  },
  {
    slug: "slider",
    name: "react-slider",
    desc: "Range slider with single and dual-thumb mode, marks, value tooltip, and full keyboard navigation.",
    version: "0.1.0",
    size: "~8 KB",
    tags: ["range", "dual thumb", "keyboard"],
  },
  {
    slug: "popover",
    name: "react-popover",
    desc: "Click or hover triggered popover with rich content, title, arrow, and smart viewport flip.",
    version: "0.1.0",
    size: "~7 KB",
    tags: ["portal", "rich content", "flip"],
  },
  {
    slug: "dropdown-menu",
    name: "react-dropdown-menu",
    desc: "Dropdown menu with items, dividers, icons, four placements, and full keyboard navigation.",
    version: "0.1.0",
    size: "~8 KB",
    tags: ["menu", "keyboard", "portal"],
  },
  {
    slug: "timeline",
    name: "react-timeline",
    desc: "Vertical timeline with status-driven dot colours, line/dashed connectors, and alignment options.",
    version: "0.1.0",
    size: "~6 KB",
    tags: ["status", "connector", "vertical"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@mshafiqyajid/packages — polished React UI primitives</title>
    <meta name="description" content="A collection of tiny, headless React components. Zero dependencies, fully typed, SSR-safe." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = saved ?? preferred;
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="home">
      <!-- Hero -->
      <section class="hero">
        <div class="hero__inner">
          <div class="hero__eyebrow">
            <span class="hero__dot"></span>
            19 packages · React · TypeScript · Zero deps
          </div>
          <h1 class="hero__title">
            Tiny, polished<br />
            <span class="hero__title-accent">React primitives.</span>
          </h1>
          <p class="hero__subtitle">
            Headless hooks and beautifully styled components. Every package ships under 25 KB, has zero runtime dependencies, and is SSR-safe.
          </p>
          <div class="hero__actions">
            <a href="/react/copy-button/" class="btn btn--primary">Browse packages</a>
            <a href="https://github.com/mshafiqyajid/packages" target="_blank" rel="noreferrer" class="btn btn--secondary">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </section>

      <!-- Packages grid -->
      <section class="packages">
        <div class="packages__inner">
          <div class="packages__header">
            <h2 class="packages__heading">All packages</h2>
            <span class="packages__count">19 packages</span>
          </div>
          <div class="packages__grid">
            {packages.map((pkg) => (
              <a href={`/react/${pkg.slug}/`} class="pkg-card">
                {pkg.highlight && (
                  <div class="pkg-card__highlight">{pkg.highlight}</div>
                )}
                <div class="pkg-card__preview" aria-hidden="true">
                  {pkg.slug === "copy-button" && <CopyButtonPreview client:visible />}
                  {pkg.slug === "otp-input" && <OTPInputPreview client:visible />}
                  {pkg.slug === "segmented-control" && <SegmentedControlPreview client:visible />}
                  {pkg.slug === "rating" && <RatingPreview client:visible />}
                  {pkg.slug === "color" && <ColorPreview client:visible />}
                  {pkg.slug === "tooltip" && <TooltipPreview client:visible />}
                  {pkg.slug === "accordion" && <AccordionPreview client:visible />}
                  {pkg.slug === "tabs" && <TabsPreview client:visible />}
                  {pkg.slug === "toast" && <ToastPreview client:visible />}
                  {pkg.slug === "select" && <SelectPreview client:visible />}
                  {pkg.slug === "modal" && <ModalPreview client:visible />}
                  {pkg.slug === "switch" && <SwitchPreview client:visible />}
                  {pkg.slug === "badge" && <BadgePreview client:visible />}
                  {pkg.slug === "avatar" && <AvatarPreview client:visible />}
                  {pkg.slug === "progress" && <ProgressPreview client:visible />}
                  {pkg.slug === "slider" && <SliderPreview client:visible />}
                  {pkg.slug === "popover" && <PopoverPreview client:visible />}
                  {pkg.slug === "dropdown-menu" && <DropdownMenuPreview client:visible />}
                  {pkg.slug === "timeline" && <TimelinePreview client:visible />}
                </div>
                <div class="pkg-card__body">
                  <div class="pkg-card__header">
                    <div class="pkg-card__name">{pkg.name}</div>
                    <div class="pkg-card__meta">
                      <span class="pkg-card__version">v{pkg.version}</span>
                      <span class="pkg-card__size">{pkg.size}</span>
                    </div>
                  </div>
                  <p class="pkg-card__desc">{pkg.desc}</p>
                  <div class="pkg-card__tags">
                    {pkg.tags.map((tag) => (
                      <span class="pkg-card__tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Feature strip -->
      <section class="features">
        <div class="features__inner">
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            <span>Zero dependencies</span>
          </div>
          <div class="features__sep" aria-hidden="true"></div>
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            <span>TypeScript-first</span>
          </div>
          <div class="features__sep" aria-hidden="true"></div>
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            <span>SSR-safe</span>
          </div>
          <div class="features__sep" aria-hidden="true"></div>
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Accessible (ARIA)</span>
          </div>
          <div class="features__sep" aria-hidden="true"></div>
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>Headless + Styled</span>
          </div>
          <div class="features__sep" aria-hidden="true"></div>
          <div class="features__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span>React 17–19</span>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <span>MIT licensed · by <a href="https://github.com/mshafiqyajid" target="_blank" rel="noreferrer">@mshafiqyajid</a></span>
        <a href="https://github.com/mshafiqyajid/packages" target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .home { padding-top: var(--header-height); min-height: 100vh; }

  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    padding: 5.5rem 1.5rem 4.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 15% -5%, rgba(99,102,241,0.12), transparent),
      radial-gradient(ellipse 50% 40% at 85% 10%, rgba(168,85,247,0.08), transparent);
    pointer-events: none;
    z-index: -1;
  }
  .hero__inner { max-width: 640px; margin: 0 auto; }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
    padding: 0.28rem 0.8rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
  }
  .hero__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
    animation: hero-pulse 2.5s ease-in-out infinite;
  }
  @keyframes hero-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
    50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0.05); }
  }
  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin-bottom: 1.1rem;
    color: var(--fg);
  }
  .hero__title-accent {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: block;
  }
  .hero__subtitle {
    font-size: 1rem;
    color: var(--fg-muted);
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .hero__actions {
    display: flex;
    gap: 0.625rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.575rem 1.15rem;
    border-radius: var(--radius);
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease, background 140ms ease;
    text-decoration: none;
    line-height: 1;
  }
  .btn:hover { transform: translateY(-1px); text-decoration: none; }
  .btn--primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 2px 12px -3px rgba(99,102,241,0.45);
  }
  .btn--primary:hover { background: var(--accent-hover); color: white; box-shadow: 0 4px 16px -3px rgba(99,102,241,0.5); }
  .btn--secondary {
    background: var(--bg-elevated);
    color: var(--fg-muted);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  .btn--secondary:hover { color: var(--fg); background: var(--bg-subtle); box-shadow: var(--shadow-md); }

  /* ── Feature strip ──────────────────────────────────────────── */
  .features {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .features__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .features__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--fg-muted);
    white-space: nowrap;
  }
  .features__item svg { color: var(--accent); flex-shrink: 0; }
  .features__sep {
    width: 1px;
    height: 14px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Packages grid ──────────────────────────────────────────── */
  .packages { padding: 3rem 1.5rem; }
  .packages__inner { max-width: 1100px; margin: 0 auto; }
  .packages__header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .packages__heading { font-size: 1.25rem; color: var(--fg); }
  .packages__count {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--fg-subtle);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .packages__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }
  .pkg-card {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
    display: flex;
    flex-direction: column;
  }
  .pkg-card__preview {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    pointer-events: none;
  }
  .pkg-card__body {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .pkg-card:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent), var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
  }
  .pkg-card__highlight {
    position: absolute;
    top: -1px; right: 10px;
    background: var(--accent);
    color: white;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 0 0 5px 5px;
    letter-spacing: 0.03em;
  }
  .pkg-card__header { display: flex; flex-direction: column; gap: 3px; }
  .pkg-card__name {
    font-size: 0.84rem;
    font-weight: 600;
    font-family: "JetBrains Mono", monospace;
    color: var(--fg);
    letter-spacing: -0.01em;
  }
  .pkg-card__meta { display: flex; gap: 0.35rem; }
  .pkg-card__version, .pkg-card__size {
    font-size: 0.67rem;
    font-family: "JetBrains Mono", monospace;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 5px;
    color: var(--fg-subtle);
  }
  .pkg-card__desc {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    line-height: 1.55;
    flex: 1;
  }
  .pkg-card__tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .pkg-card__tag {
    font-size: 0.67rem;
    font-weight: 500;
    padding: 1px 6px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
  }

  /* ── Footer ─────────────────────────────────────────────────── */
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    background: var(--bg-subtle);
  }
  .footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--fg-subtle);
  }
  .footer a { color: var(--fg-subtle); transition: color 140ms ease; }
  .footer a:hover { color: var(--fg); text-decoration: none; }
</style>
