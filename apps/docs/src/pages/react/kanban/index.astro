---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import KanbanDemo from "~/components/demos/KanbanDemo";
---
<DocLayout title="react-kanban" description="Drag-and-drop kanban board with columns, cards, intra-column reorder, drop indicator, inline add/rename, WIP limits, custom card actions." pkg="kanban">
  <PackagePageShell name="react-kanban" version="0.2.0" description="Headless kanban hook and styled component. HTML5 Drag and Drop API — no external DnD library. Cross-column moves, intra-column reorder, insert-at-index drop indicator, inline add card / rename column, hover card actions, WIP limits, canDrop validators, generic card data." size="~10 KB">
    <div class="pkg-section"><H2>Playground</H2><KanbanDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-kanban" /></div>
    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { KanbanStyled } from "@mshafiqyajid/react-kanban/styled";
import type { KanbanColumn } from "@mshafiqyajid/react-kanban";
import "@mshafiqyajid/react-kanban/styles.css";

const [columns, setColumns] = useState<KanbanColumn[]>([
  { id: "todo",  title: "To Do",       cards: [] },
  { id: "doing", title: "In Progress", cards: [] },
  { id: "done",  title: "Done",        cards: [] },
]);

<KanbanStyled columns={columns} onChange={setColumns} tone="primary" />`} />
    </div>
    <div class="pkg-section"><H2>API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>columns</td><td>KanbanColumn[]</td><td>—</td><td>Board columns with cards</td></tr>
        <tr><td>onChange</td><td>(cols) =&gt; void</td><td>—</td><td>Called when columns/cards change</td></tr>
        <tr><td>renderCard</td><td>(card, col) =&gt; ReactNode</td><td>—</td><td>Custom card renderer</td></tr>
        <tr><td>renderColumnHeader</td><td>(col) =&gt; ReactNode</td><td>—</td><td>Custom column header</td></tr>
        <tr><td>addCardPlaceholder</td><td>string</td><td>—</td><td>Label text for the "Add card" button. The "+" icon is rendered automatically — pass just the label (e.g. "Add card"). Empty input on Enter is ignored; Escape cancels.</td></tr>
        <tr><td>addColumnPlaceholder</td><td>string</td><td>—</td><td>Label text for the "Add column" button. The "+" icon is rendered automatically.</td></tr>
        <tr><td>columnMinWidth</td><td>string</td><td>"240px"</td><td>Minimum column width</td></tr>
        <tr><td>maxColumns</td><td>number</td><td>—</td><td>Limit the number of visible columns</td></tr>
        <tr><td>size</td><td>"sm" | "md" | "lg"</td><td>"md"</td><td>Card and text size</td></tr>
        <tr><td>tone</td><td>"neutral" | "primary"</td><td>"neutral"</td><td>Accent color</td></tr>
        <tr><td>disabled</td><td>boolean</td><td>false</td><td>Disable drag, add, remove, rename</td></tr>
        <tr><td>reorderable</td><td>boolean</td><td>false</td><td>Allow drag-to-reorder within the same column</td></tr>
        <tr><td>showDropIndicator</td><td>boolean</td><td>true</td><td>Render an insertion line between cards while dragging</td></tr>
        <tr><td>cardActions</td><td>{`{ id, label, icon?, onAction, show? }[]`}</td><td>—</td><td>Hover-revealed action buttons on each card</td></tr>
        <tr><td>showCardRemoveButton</td><td>boolean</td><td>false</td><td>Show a × on cards; clicking removes the card</td></tr>
        <tr><td>renameColumnInline</td><td>boolean</td><td>false</td><td>Double-click a column title to edit; Enter commits, Escape cancels</td></tr>
        <tr><td>onColumnRename</td><td>(columnId, title) =&gt; void</td><td>—</td><td>Fires when an inline rename commits</td></tr>
        <tr><td>onColumnRemove</td><td>(column) =&gt; void</td><td>—</td><td>When provided, shows × in the column header</td></tr>
        <tr><td>showWipBadge</td><td>boolean</td><td>false</td><td>Show "count / limit" instead of plain count when wipLimit is set</td></tr>
        <tr><td>onCardAdd</td><td>(card, columnId) =&gt; void</td><td>—</td><td>Card added callback</td></tr>
        <tr><td>onCardRemove</td><td>(card, columnId) =&gt; void</td><td>—</td><td>Card removed callback</td></tr>
        <tr><td>onCardMove</td><td>(card, from, to, toIndex?) =&gt; void</td><td>—</td><td>Cross-column move with destination index</td></tr>
        <tr><td>onCardReorder</td><td>(card, columnId, fromIndex, toIndex) =&gt; void</td><td>—</td><td>Intra-column reorder (requires reorderable)</td></tr>
        <tr><td>onColumnAdd</td><td>(column) =&gt; void</td><td>—</td><td>New column added</td></tr>
        <tr><td>canDrop</td><td>(card, from, to, toIndex?) =&gt; boolean</td><td>—</td><td>Validate before drop. Return false to reject.</td></tr>
        <tr><td>onDropRejected</td><td>(card, from, to, reason) =&gt; void</td><td>—</td><td>Fires on rejection. reason: "canDrop" | "limit"</td></tr>
        <tr><td>maxCardsPerColumn</td><td>number</td><td>—</td><td>Global per-column card limit (overridden by column.wipLimit)</td></tr>
        <tr><td>cardDraggable</td><td>boolean | (card, col) =&gt; boolean</td><td>true</td><td>Control per-card drag</td></tr>
        <tr><td>collapsible</td><td>boolean</td><td>false</td><td>Columns can collapse</td></tr>
      </tbody></table>
    </div>
    <div class="pkg-section"><H2>Column WIP limits</H2>
      <CodeBlock lang="tsx" code={`// Per-column hard cap and soft warn threshold.
// data-wip-state="ok" | "warn" | "over" lands on the column for styling.
const columns: KanbanColumn[] = [
  { id: "doing", title: "In Progress", cards: [...], wipLimit: 3, wipWarnThreshold: 2 },
];

<KanbanStyled columns={columns} onChange={setColumns} showWipBadge />`} />
    </div>
    <div class="pkg-section"><H2>Typed card data</H2>
      <CodeBlock lang="tsx" code={`type Task = { assignee: string; due: string };

const columns: KanbanColumn<Task>[] = [
  { id: "todo", title: "To Do", cards: [
    { id: "1", content: "Ship", data: { assignee: "MS", due: "2026-06-01" } },
  ]},
];

<KanbanStyled<Task>
  columns={columns}
  onChange={setColumns}
  renderCard={(card) => <>{card.content} — {card.data?.assignee}</>}
/>`} />
    </div>
  </PackagePageShell>
</DocLayout>
