---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import ProgressDemo from "~/components/demos/ProgressDemo";
---
<DocLayout title="react-progress" description="Progress bar and circular progress ring with indeterminate state and 5 tones." pkg="progress">
  <PackagePageShell name="react-progress" version="0.1.0" description="Headless progress hook, styled progress bar and circular ring. Indeterminate state, 5 tones, sizes, animated stripe, value display." size="~6 KB">
    <div class="pkg-section"><H2>Playground</H2><ProgressDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-progress" /></div>
    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { ProgressBar, ProgressCircle } from "@mshafiqyajid/react-progress/styled";
import "@mshafiqyajid/react-progress/styles.css";

<ProgressBar value={75} tone="primary" showValue />
<ProgressBar tone="success" animated /> {/* indeterminate */}
<ProgressCircle value={60} tone="primary" showValue />`} />
    </div>
    <div class="pkg-section"><H2>Headless</H2>
      <CodeBlock lang="tsx" code={`import { useProgress } from "@mshafiqyajid/react-progress";

const { progressProps, percent, isComplete, isIndeterminate } = useProgress({
  value: 65,
});

return (
  <div {...progressProps} className="my-bar">
    <div className="my-bar__fill" style={{ width: \`\${percent}%\` }} />
  </div>
);`} />
    </div>
    <div class="pkg-section"><H2>ProgressBar API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>value</td><td>number</td><td>—</td><td>Progress value 0–100. Omit for indeterminate</td></tr>
        <tr><td>size</td><td>"sm" | "md" | "lg"</td><td>"md"</td><td>Height</td></tr>
        <tr><td>tone</td><td>"neutral" | "primary" | "success" | "warning" | "danger"</td><td>"neutral"</td><td>Color</td></tr>
        <tr><td>label</td><td>string</td><td>—</td><td>Accessible label</td></tr>
        <tr><td>showValue</td><td>boolean</td><td>false</td><td>Show percentage text</td></tr>
        <tr><td>animated</td><td>boolean</td><td>false</td><td>Animated stripe (indeterminate)</td></tr>
        <tr><td>rounded</td><td>boolean</td><td>true</td><td>Rounded ends</td></tr>
        <tr><td>segments</td><td>number</td><td>—</td><td>When set, renders the bar as N discrete segments (data-filled lands on filled cells).</td></tr>
        <tr><td>formatValue</td><td>(percent, value) =&gt; ReactNode</td><td>—</td><td>Custom value renderer used when <code>showValue</code> is true.</td></tr>
      </tbody></table>
    </div>
    <div class="pkg-section"><H2>ProgressCircle API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>value</td><td>number</td><td>—</td><td>Progress value 0–100. Omit for indeterminate spin</td></tr>
        <tr><td>size</td><td>"sm" | "md" | "lg" | number</td><td>"md"</td><td>Size (or custom px)</td></tr>
        <tr><td>tone</td><td>"neutral" | "primary" | "success" | "warning" | "danger"</td><td>"neutral"</td><td>Color</td></tr>
        <tr><td>showValue</td><td>boolean</td><td>false</td><td>Show percentage inside ring</td></tr>
        <tr><td>strokeWidth</td><td>number</td><td>4</td><td>Ring stroke thickness</td></tr>
      </tbody></table>
    </div>
  </PackagePageShell>
</DocLayout>
