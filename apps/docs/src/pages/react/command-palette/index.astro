---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import CommandPaletteDemo from "~/components/demos/CommandPaletteDemo";
---
<DocLayout title="react-command-palette" description="⌘K command palette for React. Headless hook + styled component with fuzzy match, sections, recent items, keyboard nav, and global hotkey." pkg="command-palette">
  <PackagePageShell name="react-command-palette" description="⌘K command palette for React. Headless hook + styled component. Fuzzy match against label/hint/keywords, item grouping, recent-items section, full keyboard navigation, configurable global hotkey (⌘K / Ctrl+K). Zero dependencies, fully typed." size="~5 KB">
    <div class="pkg-section"><H2>Playground</H2><CommandPaletteDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-command-palette" /></div>

    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { CommandPaletteStyled } from "@mshafiqyajid/react-command-palette/styled";
import "@mshafiqyajid/react-command-palette/styles.css";

const items = [
  { id: "new",      label: "New file",      group: "File", shortcut: "⌘N" },
  { id: "open",     label: "Open recent",   group: "File", keywords: ["history"] },
  { id: "find",     label: "Find in files", group: "Edit", shortcut: "⌘F" },
  { id: "settings", label: "Open settings", group: "App" },
];

<CommandPaletteStyled
  items={items}
  onSelect={(item) => console.log(item.id)}
  recentStorageKey="my-app-cmd-recent"
/>`} />
      <p>Opens automatically on <kbd>⌘K</kbd> / <kbd>Ctrl+K</kbd>. Up/Down moves, Enter selects, Esc closes.</p>
    </div>

    <div class="pkg-section"><H2>Headless</H2>
      <CodeBlock lang="tsx" code={`import { useCommandPalette } from "@mshafiqyajid/react-command-palette";

const cmd = useCommandPalette({ items, onSelect });

return cmd.isOpen ? (
  <div role="dialog">
    <input {...cmd.inputProps} placeholder="Type a command…" />
    <ul {...cmd.listProps}>
      {cmd.groups.map((g) => (
        <section key={g.id}>
          <h4>{g.label}</h4>
          {g.items.map((item) => (
            <li key={item.id} {...cmd.getItemProps(item)}>{item.label}</li>
          ))}
        </section>
      ))}
    </ul>
  </div>
) : null;`} />
    </div>

    <div class="pkg-section"><H2>API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>items</td><td>CommandItem[]</td><td>—</td><td>Required. Items to render.</td></tr>
        <tr><td>onSelect</td><td>(item) =&gt; void</td><td>—</td><td>Fires on Enter / click</td></tr>
        <tr><td>defaultOpen / open / onOpenChange</td><td>boolean</td><td>false</td><td>Open state (uncontrolled or controlled)</td></tr>
        <tr><td>defaultQuery</td><td>string</td><td>""</td><td>Initial search value</td></tr>
        <tr><td>filter</td><td>(item, q) =&gt; boolean</td><td>substring match</td><td>Custom filter (fuzzy/score)</td></tr>
        <tr><td>recentStorageKey</td><td>string</td><td>—</td><td>Persists last 5 selections via localStorage</td></tr>
        <tr><td>hotkey</td><td>{`{ key, meta?, ctrl?, shift? } | null`}</td><td>{`{ key: "k", meta: true, ctrl: true }`}</td><td>Global open shortcut</td></tr>
        <tr><td>placeholder</td><td>string</td><td>"Type a command…"</td><td>Search input placeholder</td></tr>
        <tr><td>emptyText</td><td>ReactNode</td><td>"No results."</td><td>Shown when no items match</td></tr>
        <tr><td>footer</td><td>ReactNode</td><td>—</td><td>Footer slot (keyboard hints, etc)</td></tr>
      </tbody></table>
    </div>

    <div class="pkg-section"><H2>CommandItem</H2>
      <table class="props-table"><thead><tr><th>Field</th><th>Type</th><th>Description</th></tr></thead><tbody>
        <tr><td>id</td><td>string</td><td>Required, unique</td></tr>
        <tr><td>label</td><td>string</td><td>Required, matched by filter</td></tr>
        <tr><td>hint</td><td>string?</td><td>Secondary text + matched by filter</td></tr>
        <tr><td>icon</td><td>ReactNode?</td><td>Left-side icon</td></tr>
        <tr><td>shortcut</td><td>string?</td><td>Right-side keyboard hint</td></tr>
        <tr><td>group</td><td>string?</td><td>Section heading</td></tr>
        <tr><td>disabled</td><td>boolean?</td><td>Skipped by keyboard nav</td></tr>
        <tr><td>keywords</td><td>string[]?</td><td>Extra search terms</td></tr>
        <tr><td>data</td><td>T?</td><td>Free-form payload</td></tr>
      </tbody></table>
    </div>
  </PackagePageShell>
</DocLayout>
