---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import TooltipDemo from "~/components/demos/TooltipDemo";
---

<DocLayout
  title="react-tooltip"
  description="Accessible tooltip with smart flip positioning, animations, and full keyboard support."
  pkg="tooltip"
>
  <PackagePageShell
    name="react-tooltip"
    version="0.2.0"
    description="Headless tooltip hook and styled component for React. Accessible, keyboard-friendly, full placement set with -start/-end alignment, flip + shift + offset + collisionPadding, SSR-safe, fully typed."
    size="~7 KB"
  >
    <div class="pkg-section">
      <H2>Playground</H2>
      <TooltipDemo client:load />
    </div>

    <div class="pkg-section">
      <H2>Install</H2>
      <CodeBlock lang="bash" code="npm install @mshafiqyajid/react-tooltip" />
    </div>

    <div class="pkg-section">
      <H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { TooltipStyled } from "@mshafiqyajid/react-tooltip/styled";
import "@mshafiqyajid/react-tooltip/styles.css";

export function App() {
  return (
    <TooltipStyled content="Copy to clipboard" placement="top">
      <button>Copy</button>
    </TooltipStyled>
  );
}`} />
    </div>

    <div class="pkg-section">
      <H2>Placements</H2>
      <p>Each side accepts an optional <code>-start</code> or <code>-end</code> alignment. The tooltip automatically flips to the opposite side near viewport edges (toggle with <code>flip</code>) and shifts back into view along the cross-axis (toggle with <code>shift</code>).</p>
      <CodeBlock lang="tsx" code={`<TooltipStyled content="Top start"  placement="top-start">...</TooltipStyled>
<TooltipStyled content="Bottom end" placement="bottom-end">...</TooltipStyled>
<TooltipStyled content="Right" placement="right" offset={12} collisionPadding={16}>
  ...
</TooltipStyled>`} />
    </div>

    <div class="pkg-section">
      <H2>Tones</H2>
      <CodeBlock lang="tsx" code={`<TooltipStyled content="Neutral" tone="neutral">...</TooltipStyled>
<TooltipStyled content="Primary" tone="primary">...</TooltipStyled>
<TooltipStyled content="Success" tone="success">...</TooltipStyled>
<TooltipStyled content="Danger" tone="danger">...</TooltipStyled>`} />
    </div>

    <div class="pkg-section">
      <H2>Rich content</H2>
      <p>Pass any JSX to <code>content</code>. Use <code>multiline</code> to allow text to wrap.</p>
      <CodeBlock lang="tsx" code={`<TooltipStyled
  multiline
  content={
    <span>
      <strong>⌘ + C</strong> to copy
    </span>
  }
>
  <button>Copy</button>
</TooltipStyled>`} />
    </div>

    <div class="pkg-section">
      <H2>Delay</H2>
      <p>Show delay defaults to <code>0</code> (instant). Increase for less sensitive triggers.</p>
      <CodeBlock lang="tsx" code={`<TooltipStyled content="Appears after 500ms" delay={500}>...</TooltipStyled>`} />
    </div>

    <div class="pkg-section">
      <H2>Headless</H2>
      <p>Use <code>useTooltip</code> to build a fully custom tooltip with your own markup and styles.</p>
      <CodeBlock lang="tsx" code={`import { useTooltip } from "@mshafiqyajid/react-tooltip";

function MyTooltip({ content, children }) {
  const { triggerProps, tooltipProps, placement, isVisible } = useTooltip({
    placement: "top",
    delay: 300,
  });

  return (
    <div style={{ position: "relative", display: "inline-flex" }}>
      <div {...triggerProps}>{children}</div>
      <div
        {...tooltipProps}
        data-placement={placement}
        style={{
          position: "absolute",
          bottom: "calc(100% + 8px)",
          left: "50%",
          translate: "-50% 0",
          opacity: isVisible ? 1 : 0,
          transition: "opacity 140ms ease",
          background: "#18181b",
          color: "#fff",
          padding: "4px 10px",
          borderRadius: "6px",
          fontSize: "0.78rem",
          whiteSpace: "nowrap",
          pointerEvents: "none",
        }}
      >
        {content}
      </div>
    </div>
  );
}`} />
    </div>

    <div class="pkg-section">
      <H2>API</H2>
      <table class="props-table">
        <thead>
          <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td>content</td><td>ReactNode</td><td>—</td><td>Tooltip text or JSX content</td></tr>
          <tr><td>placement</td><td>top | bottom | left | right (each with optional -start / -end)</td><td>"top"</td><td>Preferred side and alignment</td></tr>
          <tr><td>size</td><td>"sm" | "md" | "lg"</td><td>"md"</td><td>Size of the tooltip bubble</td></tr>
          <tr><td>tone</td><td>"neutral" | "primary" | "success" | "danger"</td><td>"neutral"</td><td>Color tone</td></tr>
          <tr><td>delay</td><td>number</td><td>0</td><td>Show delay in ms</td></tr>
          <tr><td>multiline</td><td>boolean</td><td>false</td><td>Allow content to wrap</td></tr>
          <tr><td>disabled</td><td>boolean</td><td>false</td><td>Disable the tooltip entirely</td></tr>
          <tr><td>offset</td><td>number</td><td>8</td><td>Gap between trigger and tooltip</td></tr>
          <tr><td>collisionPadding</td><td>number</td><td>8</td><td>Viewport edge margin for flip / shift</td></tr>
          <tr><td>flip</td><td>boolean</td><td>true</td><td>Auto-flip to opposite side near edges</td></tr>
          <tr><td>shift</td><td>boolean</td><td>true</td><td>Push back into view along the cross-axis</td></tr>
          <tr><td>strategy</td><td>"absolute" | "fixed"</td><td>"absolute"</td><td>Positioning strategy</td></tr>
        </tbody>
      </table>
    </div>
  </PackagePageShell>
</DocLayout>
