---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import SwitchDemo from "~/components/demos/SwitchDemo";
---
<DocLayout title="react-switch" description="Toggle switch with sizes, tones, label, and loading state." pkg="switch">
  <PackagePageShell name="react-switch" version="0.1.0" description="Headless toggle switch hook and styled component. Controlled and uncontrolled, sizes, tones, label positioning, loading spinner." size="~5 KB">
    <div class="pkg-section"><H2>Playground</H2><SwitchDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-switch" /></div>
    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { SwitchStyled } from "@mshafiqyajid/react-switch/styled";
import "@mshafiqyajid/react-switch/styles.css";

const [on, setOn] = useState(false);
<SwitchStyled checked={on} onChange={setOn} label="Enable notifications" />`} />
    </div>
    <div class="pkg-section"><H2>API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>checked</td><td>boolean</td><td>—</td><td>Controlled checked state</td></tr>
        <tr><td>defaultChecked</td><td>boolean</td><td>false</td><td>Uncontrolled initial state</td></tr>
        <tr><td>onChange</td><td>(v: boolean) =&gt; void</td><td>—</td><td>Called on toggle</td></tr>
        <tr><td>size</td><td>"sm" | "md" | "lg"</td><td>"md"</td><td>Size</td></tr>
        <tr><td>tone</td><td>"neutral" | "primary" | "success" | "danger"</td><td>"primary"</td><td>Color when on</td></tr>
        <tr><td>label</td><td>ReactNode</td><td>—</td><td>Label text</td></tr>
        <tr><td>labelPosition</td><td>"left" | "right"</td><td>"right"</td><td>Label side</td></tr>
        <tr><td>loading</td><td>boolean</td><td>false</td><td>Show spinner in thumb</td></tr>
        <tr><td>disabled</td><td>boolean</td><td>false</td><td>Disable the switch</td></tr>
      </tbody></table>
    </div>
  </PackagePageShell>
</DocLayout>
