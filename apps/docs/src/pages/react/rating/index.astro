---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import RatingDemo from "~/components/demos/RatingDemo";
---

<DocLayout
  title="react-rating"
  description="Star rating with half-step support, hover preview, custom icons."
  pkg="rating"
>
  <PackagePageShell
    name="react-rating"
    description="Headless star-rating hook and styled component for React. Half-step support, hover preview, custom icons (hearts, thumbs, anything), full keyboard nav, CSS clip-path half-fill. Async onChange (Promise-driven pending state with revert on rejection). Form-input contract: name + hidden input, error / invalid / required."
    size="~19 KB"
  >
    <div class="pkg-section">
      <H2>Playground</H2>
      <RatingDemo client:load />
    </div>

    <div class="pkg-section">
      <H2>Install</H2>
      <CodeBlock lang="bash" code="npm install @mshafiqyajid/react-rating" />
    </div>

    <div class="pkg-section">
      <H2>Quick start</H2>
      <CodeBlock code={`import { RatingStyled } from "@mshafiqyajid/react-rating/styled";
import "@mshafiqyajid/react-rating/styles.css";

const [value, setValue] = useState(0);

<RatingStyled
  count={5}
  value={value}
  onChange={setValue}
  showValue
/>`} />
    </div>

    <div class="pkg-section">
      <H2>Recipes</H2>

      <h3>Read-only display (e.g. average rating)</h3>
      <CodeBlock code={`<RatingStyled
  count={5}
  value={4.5}
  readOnly
  showValue
  label="Average rating"
/>`} />

      <h3>Heart icon</h3>
      <CodeBlock code={`<RatingStyled
  count={5}
  tone="danger"
  icon={<HeartIcon />}
  defaultValue={3}
/>`} />

      <h3>Async submit (Promise-driven pending state)</h3>
      <p>Return a <code>Promise</code> from <code>onChange</code> to drive <code>data-pending</code> automatically. Stars are non-interactive while the promise is in flight; on rejection the value reverts.</p>
      <CodeBlock code={`<RatingStyled
  count={5}
  defaultValue={0}
  onChange={async (next) => {
    await fetch("/api/reviews", {
      method: "POST",
      body: JSON.stringify({ stars: next }),
    });
  }}
/>`} />

      <h3>Per-star labels with onHover</h3>
      <CodeBlock code={`const labels = ["Terrible", "Poor", "OK", "Good", "Great"];
const [hovered, setHovered] = useState<number | null>(null);

<>
  <RatingStyled
    count={5}
    value={value}
    onChange={setValue}
    onHover={setHovered}
  />
  <span>{labels[Math.ceil((hovered ?? value) - 1)] ?? ""}</span>
</>`} />
    </div>

    <div class="pkg-section">
      <H2>API</H2>
      <h3>RatingStyled</h3>
      <table class="props-table">
        <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
          <tr><td>count</td><td>number</td><td>5</td><td>Number of stars.</td></tr>
          <tr><td>value</td><td>number</td><td>—</td><td>Controlled value (0..count).</td></tr>
          <tr><td>defaultValue</td><td>number</td><td>0</td><td>Uncontrolled initial.</td></tr>
          <tr><td>onChange</td><td>(value: number) =&gt; void | Promise&lt;void&gt;</td><td>—</td><td>Fires on commit. Return a Promise to auto-drive a pending state; reverts on rejection.</td></tr>
          <tr><td>onHover</td><td>(value: number | null) =&gt; void</td><td>—</td><td>Fires during hover.</td></tr>
          <tr><td>allowHalf</td><td>boolean</td><td>true</td><td>Enable half-step values.</td></tr>
          <tr><td>clearable</td><td>boolean</td><td>true</td><td>Re-clicking active value clears it.</td></tr>
          <tr><td>readOnly</td><td>boolean</td><td>false</td><td>Display only, no interaction.</td></tr>
          <tr><td>size</td><td>sm | md | lg</td><td>md</td><td>Size.</td></tr>
          <tr><td>tone</td><td>neutral | primary | success | warning | danger</td><td>warning</td><td>Fill color.</td></tr>
          <tr><td>icon</td><td>ReactNode</td><td>star SVG</td><td>Custom icon for both layers.</td></tr>
          <tr><td>showValue</td><td>boolean</td><td>false</td><td>Show numeric value badge.</td></tr>
          <tr><td>label</td><td>ReactNode</td><td>—</td><td>Label above.</td></tr>
          <tr><td>hint</td><td>ReactNode</td><td>—</td><td>Helper text below.</td></tr>
        </tbody>
      </table>
    </div>
  </PackagePageShell>
</DocLayout>
