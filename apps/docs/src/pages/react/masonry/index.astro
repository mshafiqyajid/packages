---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import MasonryDemo from "~/components/demos/MasonryDemo";
---
<DocLayout title="react-masonry" description="Headless masonry hook and CSS-columns masonry layout for React. No JS measurement." pkg="masonry">
  <PackagePageShell name="react-masonry" description="CSS-columns masonry layout. No ResizeObserver, no JS measurement — just fast, SSR-friendly column flow with a clean React API." size="~3 KB">
    <div class="pkg-section"><H2>Playground</H2><MasonryDemo client:load /></div>

    <div class="pkg-section"><H2>Install</H2>
      <CodeBlock lang="bash" code="npm install @mshafiqyajid/react-masonry" />
    </div>

    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { MasonryStyled } from "@mshafiqyajid/react-masonry/styled";
import "@mshafiqyajid/react-masonry/styles.css";

<MasonryStyled columns={3} spacing={16}>
  <div>Card 1</div>
  <div>Card 2</div>
  <div>Card 3</div>
</MasonryStyled>`} />
    </div>

    <div class="pkg-section"><H2>Responsive columns</H2>
      <CodeBlock lang="tsx" code={`// Pass a breakpoint map — columns update on window resize
<MasonryStyled
  columns={{ default: 1, 768: 2, 1024: 3, 1280: 4 }}
  spacing={24}
>
  {items.map((item) => (
    <div key={item.id}>{item.content}</div>
  ))}
</MasonryStyled>`} />
    </div>

    <div class="pkg-section"><H2>Polymorphic container</H2>
      <CodeBlock lang="tsx" code={`// Render as any element
<MasonryStyled as="section" columns={3} spacing={16}>
  {items.map((item) => <article key={item.id}>{item.content}</article>)}
</MasonryStyled>`} />
    </div>

    <div class="pkg-section"><H2>Headless hook</H2>
      <CodeBlock lang="tsx" code={`import { useMasonry } from "@mshafiqyajid/react-masonry";
import React from "react";

function MyMasonry({ children }: { children: React.ReactNode }) {
  const { containerProps, getItemProps, activeColumns } = useMasonry({
    columns: { default: 1, 768: 2, 1024: 3 },
    spacing: 20,
  });

  return (
    <div
      {...containerProps}
      className="my-masonry"
      style={{ ...containerProps.style }}
    >
      {React.Children.map(children, (child) => (
        <div {...getItemProps()}>{child}</div>
      ))}
    </div>
  );
}`} />
    </div>

    <div class="pkg-section"><H2>CSS variables</H2>
      <CodeBlock lang="css" code={`:root {
  --rmsn-columns: 3;        /* column count */
  --rmsn-gap: 16px;         /* gap between items */
  --rmsn-item-radius: 0px;  /* border-radius on each item wrapper */
}`} />
    </div>

    <div class="pkg-section"><H2>How it works</H2>
      <p class="pkg-note">
        Uses CSS <code>column-count</code> with <code>break-inside: avoid</code> on each item. No <code>position: absolute</code>, no <code>ResizeObserver</code> for layout. Items flow naturally top-to-bottom in each column. This approach is fast, SSR-compatible, and has zero runtime layout dependencies. The trade-off: items fill columns sequentially (top-to-bottom), not balanced by height — which is ideal for most card feeds.
      </p>
    </div>

    <div class="pkg-section"><H2>API — MasonryStyled</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>columns</td><td>number | BreakpointMap</td><td>3</td><td>Column count or responsive map e.g. <code>{`{ default: 1, 768: 2, 1024: 3 }`}</code></td></tr>
        <tr><td>spacing</td><td>number | string</td><td>16</td><td>Gap between items — number is treated as px, string is passed as-is</td></tr>
        <tr><td>as</td><td>ElementType</td><td>"div"</td><td>Polymorphic container element</td></tr>
        <tr><td>children</td><td>ReactNode</td><td>—</td><td>Direct children are each wrapped in a <code>.rmsn-item</code> div with <code>role="listitem"</code></td></tr>
        <tr><td>className</td><td>string</td><td>—</td><td>Extra class on the root element</td></tr>
        <tr><td>style</td><td>CSSProperties</td><td>—</td><td>Inline style override (merged with layout CSS vars)</td></tr>
        <tr><td>ref</td><td>Ref&lt;HTMLElement&gt;</td><td>—</td><td>Forwarded to the root element</td></tr>
      </tbody></table>
    </div>

    <div class="pkg-section"><H2>API — useMasonry hook</H2>
      <table class="props-table"><thead><tr><th>Option</th><th>Type</th><th>Description</th></tr></thead><tbody>
        <tr><td>columns</td><td>number | BreakpointMap</td><td>Column count or responsive breakpoint map</td></tr>
        <tr><td>spacing</td><td>number | string</td><td>Gap between items</td></tr>
      </tbody></table>
      <p class="pkg-note">Returns <code>containerProps</code> (role, style, data-columns), <code>getItemProps()</code> (role, className), and <code>activeColumns</code>.</p>
    </div>
  </PackagePageShell>
</DocLayout>
