---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import SkeletonDemo from "~/components/demos/SkeletonDemo";
---
<DocLayout title="react-skeleton" description="Accessible skeleton loading placeholders with pulse and wave animations for React." pkg="skeleton">
  <PackagePageShell name="react-skeleton" description="Headless skeleton hook and styled loading placeholder. Four variants (rect/line/circle/text), pulse and wave animations, configurable radius, and reduced-motion support." size="~2 KB">
    <div class="pkg-section"><H2>Playground</H2><SkeletonDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-skeleton" /></div>
    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { SkeletonStyled } from "@mshafiqyajid/react-skeleton/styled";
import "@mshafiqyajid/react-skeleton/styles.css";

// Rectangle placeholder
<SkeletonStyled width="100%" height={20} />

// Circle avatar
<SkeletonStyled variant="circle" width="2.5rem" height="2.5rem" />

// Text block (3 lines, last at 60%)
<SkeletonStyled variant="text" lines={3} lastLineWidth="60%" />

// Wave shimmer
<SkeletonStyled animation="wave" width="100%" height={80} />`} />
    </div>
    <div class="pkg-section"><H2>Card skeleton composition</H2>
      <CodeBlock lang="tsx" code={`import { SkeletonStyled } from "@mshafiqyajid/react-skeleton/styled";
import "@mshafiqyajid/react-skeleton/styles.css";

function CardSkeleton() {
  return (
    <div style={{ display: "flex", gap: "1rem", alignItems: "flex-start" }}>
      <SkeletonStyled variant="circle" width="2.5rem" height="2.5rem" />
      <div style={{ flex: 1, display: "flex", flexDirection: "column", gap: "0.5rem" }}>
        <SkeletonStyled variant="line" height="0.875rem" width="60%" />
        <SkeletonStyled variant="line" height="0.75rem" width="40%" />
        <SkeletonStyled variant="text" lines={3} />
      </div>
    </div>
  );
}`} />
    </div>
    <div class="pkg-section"><H2>Headless</H2>
      <CodeBlock lang="tsx" code={`import { useSkeleton } from "@mshafiqyajid/react-skeleton";

function MySkeleton() {
  const { skeletonProps } = useSkeleton();
  return (
    <div {...skeletonProps} className="my-skeleton">
      {/* your placeholder shape */}
    </div>
  );
}`} />
    </div>
    <div class="pkg-section"><H2>API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>variant</td><td>"rect" | "line" | "circle" | "text"</td><td>"rect"</td><td>Shape variant</td></tr>
        <tr><td>animation</td><td>"pulse" | "wave" | "none"</td><td>"pulse"</td><td>Animation style</td></tr>
        <tr><td>width</td><td>string | number</td><td>—</td><td>Width (e.g. "100%", 200, "12rem")</td></tr>
        <tr><td>height</td><td>string | number</td><td>—</td><td>Height (e.g. 20, "1rem")</td></tr>
        <tr><td>radius</td><td>"none" | "sm" | "md" | "lg" | "full"</td><td>"sm"</td><td>Border radius</td></tr>
        <tr><td>lines</td><td>number</td><td>3</td><td>Number of lines (text variant only)</td></tr>
        <tr><td>lastLineWidth</td><td>string</td><td>"60%"</td><td>Width of last line (text variant only)</td></tr>
        <tr><td>className</td><td>string</td><td>—</td><td>Extra class on root</td></tr>
        <tr><td>style</td><td>CSSProperties</td><td>—</td><td>Inline style override</td></tr>
      </tbody></table>
    </div>
  </PackagePageShell>
</DocLayout>
