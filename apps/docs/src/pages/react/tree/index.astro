---
import DocLayout from "~/layouts/DocLayout.astro";
import PackagePageShell from "~/components/PackagePageShell.astro";
import H2 from "~/components/H2.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import TreeDemo from "~/components/demos/TreeDemo";
---
<DocLayout title="react-tree" description="Headless tree view for React. Expand/collapse, single or multi-select, async children loading, full keyboard navigation, indent guides." pkg="tree">
  <PackagePageShell name="react-tree" description="Headless tree view + styled component. Expand/collapse, single or multi-select, async children loader, full keyboard navigation (← → ↑ ↓ Home End Enter), indent guide lines, ARIA tree pattern. Zero dependencies, fully typed." size="~5 KB">
    <div class="pkg-section"><H2>Playground</H2><TreeDemo client:load /></div>
    <div class="pkg-section"><H2>Install</H2><CodeBlock lang="bash" code="npm install @mshafiqyajid/react-tree" /></div>

    <div class="pkg-section"><H2>Quick start</H2>
      <CodeBlock lang="tsx" code={`import { TreeStyled } from "@mshafiqyajid/react-tree/styled";
import "@mshafiqyajid/react-tree/styles.css";

const items = [
  { id: "src", label: "src", children: [
    { id: "components", label: "components", children: [
      { id: "Button.tsx", label: "Button.tsx" },
    ]},
    { id: "index.ts", label: "index.ts" },
  ]},
  { id: "package.json", label: "package.json" },
];

<TreeStyled
  items={items}
  defaultExpandedIds={["src"]}
  onSelectedChange={(id) => console.log(id)}
/>`} />
    </div>

    <div class="pkg-section"><H2>Async children</H2>
      <CodeBlock lang="tsx" code={`<TreeStyled
  items={[{ id: "root", label: "root", children: undefined }]}
  loadChildren={async (node) => {
    const res = await fetch("/api/children/" + node.id);
    return res.json();
  }}
/>`} />
      <p>When a node has <code>children: undefined</code> AND a <code>loadChildren</code> is set, expanding it triggers the loader. The chevron is replaced with a spinner during the request.</p>
    </div>

    <div class="pkg-section"><H2>Multi-select</H2>
      <CodeBlock lang="tsx" code={`<TreeStyled
  items={items}
  selectionMode="multiple"
  onSelectedIdsChange={(ids) => setSelection(ids)}
/>`} />
    </div>

    <div class="pkg-section"><H2>Keyboard navigation</H2>
      <table class="props-table"><thead><tr><th>Key</th><th>Action</th></tr></thead><tbody>
        <tr><td>↓ / ↑</td><td>Move focus between visible nodes</td></tr>
        <tr><td>→</td><td>Expand collapsed parent / move to first child</td></tr>
        <tr><td>←</td><td>Collapse expanded parent / move to parent</td></tr>
        <tr><td>Home / End</td><td>Jump to first / last visible node</td></tr>
        <tr><td>Enter / Space</td><td>Select the focused node</td></tr>
      </tbody></table>
    </div>

    <div class="pkg-section"><H2>Headless</H2>
      <CodeBlock lang="tsx" code={`import { useTree } from "@mshafiqyajid/react-tree";

const tree = useTree({ items, defaultExpandedIds: ["src"] });

return (
  <ul {...tree.getRootProps()}>
    {tree.visibleNodes.map(({ node, depth, hasChildren }) => (
      <li key={node.id} {...tree.getNodeProps(node, depth)} style={{ paddingLeft: depth * 18 }}>
        {hasChildren && (
          <button {...tree.getToggleProps(node)}>
            {tree.isExpanded(node.id) ? "▾" : "▸"}
          </button>
        )}
        {node.label}
      </li>
    ))}
  </ul>
);`} />
    </div>

    <div class="pkg-section"><H2>API</H2>
      <table class="props-table"><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
        <tr><td>items</td><td>TreeNode[]</td><td>—</td><td>Required</td></tr>
        <tr><td>defaultExpandedIds / expandedIds / onExpandedChange</td><td>string[] / (ids) =&gt; void</td><td>[]</td><td>Expanded ids (uncontrolled or controlled)</td></tr>
        <tr><td>defaultSelectedId / selectedId / onSelectedChange</td><td>string | null / (id, node) =&gt; void</td><td>null</td><td>Single-selected id</td></tr>
        <tr><td>selectionMode</td><td>"single" | "multiple"</td><td>"single"</td><td>—</td></tr>
        <tr><td>selectedIds / onSelectedIdsChange</td><td>string[] / (ids) =&gt; void</td><td>—</td><td>Multi-select state (when selectionMode="multiple")</td></tr>
        <tr><td>loadChildren</td><td>(node) =&gt; Promise&lt;TreeNode[]&gt;</td><td>—</td><td>Async children loader</td></tr>
        <tr><td>size</td><td>"sm" | "md" | "lg"</td><td>"md"</td><td>Row size</td></tr>
        <tr><td>tone</td><td>"neutral" | "primary"</td><td>"primary"</td><td>Accent color</td></tr>
        <tr><td>showGuides</td><td>boolean</td><td>true</td><td>Vertical indent guide lines</td></tr>
        <tr><td>renderLabel</td><td>(node, depth) =&gt; ReactNode</td><td>—</td><td>Custom label renderer</td></tr>
      </tbody></table>
    </div>

    <div class="pkg-section"><H2>TreeNode</H2>
      <table class="props-table"><thead><tr><th>Field</th><th>Type</th><th>Description</th></tr></thead><tbody>
        <tr><td>id</td><td>string</td><td>Required, unique</td></tr>
        <tr><td>label</td><td>ReactNode</td><td>Required</td></tr>
        <tr><td>children</td><td>TreeNode[] | undefined</td><td><code>undefined</code> = leaf or async-loadable. <code>[]</code> = empty branch.</td></tr>
        <tr><td>icon</td><td>ReactNode?</td><td>Left-side icon</td></tr>
        <tr><td>disabled</td><td>boolean?</td><td>Greyed, can't toggle/select</td></tr>
        <tr><td>data</td><td>T?</td><td>Free-form payload</td></tr>
      </tbody></table>
    </div>
  </PackagePageShell>
</DocLayout>
